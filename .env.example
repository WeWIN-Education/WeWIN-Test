# Copy to .env.local and fill in your values:
#   cp .env.example .env.local

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Optional credentials login users. If empty, the app keeps the demo users
# from app/lib/users.ts.
# Generate a bcrypt hash:
#   node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"
CREDENTIAL_USERS_JSON=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Drive — folder for Speaking audio uploads (share Editor with test accounts)
GOOGLE_DRIVE_SPEAKING_FOLDER_ID=
NEXT_PUBLIC_GOOGLE_DRIVE_SPEAKING_FOLDER_ID=

# Google Sheets — HTO Ielts Test Management spreadsheet ID
GOOGLE_SHEETS_ID=
NEXT_PUBLIC_GOOGLE_SHEETS_ID=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Apps Script Web App fallback for email/password login sessions.
GOOGLE_APPS_SCRIPT_WEB_APP_URL=
NEXT_PUBLIC_GOOGLE_APPS_SCRIPT_WEB_APP_URL=
GOOGLE_APPS_SCRIPT_WEBHOOK_SECRET=
